    <script>
        const lessons = [
            {
                id: 1,
                title: "Introduction to HTML",
                difficulty: "beginner",
                content: `
                    <h3>What is HTML?</h3>
                    <p>HTML (HyperText Markup Language) is the standard markup language for creating web pages. It describes the structure of a web page and consists of a series of elements or tags.</p>
                    
                    <h3>Why HTML Matters</h3>
                    <ul>
                        <li><strong>Foundation:</strong> Every website uses HTML as its foundation</li>
                        <li><strong>Semantic:</strong> Elements describe meaning, not presentation</li>
                        <li><strong>Universal:</strong> Works across all browsers and devices</li>
                        <li><strong>Standard:</strong> Maintained by W3C and WHATWG</li>
                        <li><strong>Accessible:</strong> Built-in support for screen readers</li>
                    </ul>
                    
                    <div class="highlight-box">
                        <strong>HISTORY:</strong> HTML was created by Tim Berners-Lee in 1991. HTML5, the current version, was standardized in 2014 and brought semantic elements, multimedia support, and mobile-friendly features.
                    </div>

                    <h3>Your First HTML Document</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;!DOCTYPE html&gt;</span>
<span class="tag">&lt;html&gt;</span>
<span class="tag">&lt;head&gt;</span>
    <span class="tag">&lt;title&gt;</span>My First Page<span class="tag">&lt;/title&gt;</span>
<span class="tag">&lt;/head&gt;</span>
<span class="tag">&lt;body&gt;</span>
    <span class="tag">&lt;h1&gt;</span>Hello, World!<span class="tag">&lt;/h1&gt;</span>
    <span class="tag">&lt;p&gt;</span>This is my first webpage.<span class="tag">&lt;/p&gt;</span>
<span class="tag">&lt;/body&gt;</span>
<span class="tag">&lt;/html&gt;</span>
                    </div>

                    <h3>Key Concepts</h3>
                    <ul>
                        <li><strong>Elements:</strong> Building blocks wrapped in tags like &lt;p&gt;...&lt;/p&gt;</li>
                        <li><strong>Attributes:</strong> Additional info like href="url" in &lt;a&gt;</li>
                        <li><strong>Nesting:</strong> Elements inside other elements</li>
                        <li><strong>Structure:</strong> Head contains metadata, body contains visible content</li>
                    </ul>
                `,
                quiz: [
                    { question: "HTML stands for _____ Markup Language.", answer: "HyperText", hint: "Not just text" },
                    { question: "The visible content goes in the _____ tag.", answer: "body", hint: "Not head" },
                    { question: "The _____ element contains page metadata.", answer: "head", hint: "Not header" },
                    { question: "HTML elements are wrapped in _____.", answer: "tags", hint: "Angle brackets" },
                    { question: "&lt;!DOCTYPE html&gt; declares the _____ type.", answer: "document", hint: "Not HTML5" },
                    { question: "HTML is maintained by _____ and WHATWG.", answer: "W3C", hint: "World Wide Web Consortium" },
                    { question: "Elements can have _____.", answer: "attributes", hint: "Additional properties" },
                    { question: "HTML5 was standardized in _____.", answer: "2014", hint: "Four digits" }
                ]
            },
            {
                id: 2,
                title: "HTML Document Structure",
                difficulty: "beginner",
                content: `
                    <h3>The DOCTYPE Declaration</h3>
                    <p>Every HTML document must start with a DOCTYPE declaration. This tells the browser which version of HTML to use.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;!DOCTYPE html&gt;</span>
                    </div>

                    <h3>The HTML Element</h3>
                    <p>The &lt;html&gt; element is the root element that wraps all content. Always include the lang attribute for accessibility.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;html</span> <span class="attr">lang</span>=<span class="string">"en"</span><span class="tag">&gt;</span>
    <span class="comment">&lt;!-- All content here --&gt;</span>
<span class="tag">&lt;/html&gt;</span>
                    </div>

                    <h3>The Head Section</h3>
                    <p>The &lt;head&gt; contains metadata about the document. This information isn't displayed but is crucial for SEO, styling, and functionality.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;head&gt;</span>
    <span class="tag">&lt;meta</span> <span class="attr">charset</span>=<span class="string">"UTF-8"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;meta</span> <span class="attr">name</span>=<span class="string">"viewport"</span> <span class="attr">content</span>=<span class="string">"width=device-width, initial-scale=1.0"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;meta</span> <span class="attr">name</span>=<span class="string">"description"</span> <span class="attr">content</span>=<span class="string">"Learn HTML"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;title&gt;</span>Page Title<span class="tag">&lt;/title&gt;</span>
    <span class="tag">&lt;link</span> <span class="attr">rel</span>=<span class="string">"stylesheet"</span> <span class="attr">href</span>=<span class="string">"styles.css"</span><span class="tag">&gt;</span>
<span class="tag">&lt;/head&gt;</span>
                    </div>

                    <h3>Essential Meta Tags</h3>
                    <ul>
                        <li><strong>charset:</strong> Character encoding (UTF-8)</li>
                        <li><strong>viewport:</strong> Responsive design settings</li>
                        <li><strong>description:</strong> SEO meta description</li>
                        <li><strong>author:</strong> Page author</li>
                    </ul>

                    <h3>The Body Section</h3>
                    <p>The &lt;body&gt; contains all visible content: text, images, links, forms, and more.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;body&gt;</span>
    <span class="comment">&lt;!-- All visible content goes here --&gt;</span>
    <span class="tag">&lt;header&gt;</span><span class="tag">&lt;/header&gt;</span>
    <span class="tag">&lt;main&gt;</span><span class="tag">&lt;/main&gt;</span>
    <span class="tag">&lt;footer&gt;</span><span class="tag">&lt;/footer&gt;</span>
<span class="tag">&lt;/body&gt;</span>
                    </div>

                    <h3>Complete Structure</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;!DOCTYPE html&gt;</span>
<span class="tag">&lt;html</span> <span class="attr">lang</span>=<span class="string">"en"</span><span class="tag">&gt;</span>
<span class="tag">&lt;head&gt;</span>
    <span class="tag">&lt;meta</span> <span class="attr">charset</span>=<span class="string">"UTF-8"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;meta</span> <span class="attr">name</span>=<span class="string">"viewport"</span> <span class="attr">content</span>=<span class="string">"width=device-width, initial-scale=1.0"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;title&gt;</span>Document<span class="tag">&lt;/title&gt;</span>
<span class="tag">&lt;/head&gt;</span>
<span class="tag">&lt;body&gt;</span>
    <span class="tag">&lt;h1&gt;</span>Hello World<span class="tag">&lt;/h1&gt;</span>
<span class="tag">&lt;/body&gt;</span>
<span class="tag">&lt;/html&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "The _____ declares the document type.", answer: "DOCTYPE", hint: "Not DOCTYPEe" },
                    { question: "The root element is _____.", answer: "html", hint: "Wraps everything" },
                    { question: "The _____ contains metadata.", answer: "head", hint: "Not header" },
                    { question: "UTF-8 is a _____ encoding.", answer: "character", hint: "Text encoding" },
                    { question: "The _____ tag makes sites mobile-friendly.", answer: "viewport", hint: "Meta tag" },
                    { question: "All visible content goes in the _____.", answer: "body", hint: "Not head" },
                    { question: "The _____ element sets the page title.", answer: "title", hint: "In head section" },
                    { question: "Always set the _____ attribute on html.", answer: "lang", hint: "Language code" }
                ]
            },
            {
                id: 3,
                title: "Text Elements & Headings",
                difficulty: "beginner",
                content: `
                    <h3>Headings: H1 Through H6</h3>
                    <p>HTML provides six levels of headings. Use them hierarchically—only one H1 per page for the main title.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;h1&gt;</span>Main Heading (Most Important)<span class="tag">&lt;/h1&gt;</span>
<span class="tag">&lt;h2&gt;</span>Section Heading<span class="tag">&lt;/h2&gt;</span>
<span class="tag">&lt;h3&gt;</span>Subsection Heading<span class="tag">&lt;/h3&gt;</span>
<span class="tag">&lt;h4&gt;</span>Sub-subsection<span class="tag">&lt;/h4&gt;</span>
<span class="tag">&lt;h5&gt;</span>Minor Heading<span class="tag">&lt;/h5&gt;</span>
<span class="tag">&lt;h6&gt;</span>Least Important<span class="tag">&lt;/h6&gt;</span>
                    </div>

                    <h3>Paragraphs</h3>
                    <p>The &lt;p&gt; element defines a paragraph of text.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;p&gt;</span>This is a paragraph of text. Browsers automatically add margins before and after paragraphs.<span class="tag">&lt;/p&gt;</span>
<span class="tag">&lt;p&gt;</span>This is another paragraph.<span class="tag">&lt;/p&gt;</span>
                    </div>

                    <h3>Text Formatting Elements</h3>
                    <p>HTML provides inline elements for formatting text without creating new blocks.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;p&gt;</span>
    <span class="tag">&lt;strong&gt;</span>Bold (important)<span class="tag">&lt;/strong&gt;</span> text<br<span class="tag">&gt;</span>
    <span class="tag">&lt;b&gt;</span>Bold (visual)<span class="tag">&lt;/b&gt;</span> text<br<span class="tag">&gt;</span>
    <span class="tag">&lt;em&gt;</span>Italic (emphasized)<span class="tag">&lt;/em&gt;</span><br<span class="tag">&gt;</span>
    <span class="tag">&lt;i&gt;</span>Italic (visual)<span class="tag">&lt;/i&gt;</span><br<span class="tag">&gt;</span>
    <span class="tag">&lt;u&gt;</span>Underlined<span class="tag">&lt;/u&gt;</span> text<br<span class="tag">&gt;</span>
    <span class="tag">&lt;s&gt;</span>Strikethrough<span class="tag">&lt;/s&gt;</span><br<span class="tag">&gt;</span>
    <span class="tag">&lt;code&gt;</span>Code<span class="tag">&lt;/code&gt;</span><br<span class="tag">&gt;</span>
    <span class="tag">&lt;small&gt;</span>Small text<span class="tag">&lt;/small&gt;</span>
<span class="tag">&lt;/p&gt;</span>
                    </div>

                    <h3>Line Breaks and Horizontal Rules</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;p&gt;</span>First line<span class="tag">&lt;br&gt;</span>Second line<span class="tag">&lt;/p&gt;</span>
<span class="tag">&lt;hr&gt;</span>
<span class="tag">&lt;p&gt;</span>New section<span class="tag">&lt;/p&gt;</span>
                    </div>

                    <h3>Preformatted Text</h3>
                    <p>Use &lt;pre&gt; to preserve whitespace and formatting—great for code blocks.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;pre&gt;</span>
function hello() {
    console.log("Hello!");
}
<span class="tag">&lt;/pre&gt;</span>
                    </div>

                    <h3>Blockquotes and Citations</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;blockquote&gt;</span>
    <span class="tag">&lt;p&gt;</span>"The Web is designed to be universal: to include everyone's information regardless of the browser."<span class="tag">&lt;/p&gt;</span>
    <span class="tag">&lt;cite&gt;</span>— Tim Berners-Lee<span class="tag">&lt;/cite&gt;</span>
<span class="tag">&lt;/blockquote&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "Use _____ for the main page title.", answer: "h1", hint: "Only one per page" },
                    { question: "The _____ element defines a paragraph.", answer: "p", hint: "Lowercase" },
                    { question: "Use _____ for important text.", answer: "strong", hint: "Not bold" },
                    { question: "Use _____ for emphasized text.", answer: "em", hint: "Not italic" },
                    { question: "Use _____ to preserve whitespace.", answer: "pre", hint: "Preformatted" },
                    { question: "Create a line break with _____.", answer: "br", hint: "Self-closing" },
                    { question: "Use _____ for a thematic break.", answer: "hr", hint: "Horizontal rule" },
                    { question: "Use _____ for quoted text.", answer: "blockquote", hint: "Block element" }
                ]
            },
            {
                id: 4,
                title: "Links and Navigation",
                difficulty: "beginner",
                content: `
                    <h3>The Anchor Element</h3>
                    <p>The &lt;a&gt; (anchor) element creates hyperlinks to other pages, files, or locations within the same page.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"https://example.com"</span><span class="tag">&gt;</span>Visit Example<span class="tag">&lt;/a&gt;</span>
                    </div>

                    <h3>Essential Attributes</h3>
                    <ul>
                        <li><strong>href:</strong> The URL the link points to</li>
                        <li><strong>target:</strong> Where to open the link (_blank for new tab)</li>
                        <li><strong>title:</strong> Tooltip text on hover</li>
                        <li><strong>rel:</strong> Relationship (nofollow, noopener)</li>
                    </ul>

                    <h3>Link Types</h3>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- External link --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"https://google.com"</span> <span class="attr">target</span>=<span class="string">"_blank"</span><span class="tag">&gt;</span>Google<span class="tag">&lt;/a&gt;</span>

<span class="comment">&lt;!-- Internal link --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"/about.html"</span><span class="tag">&gt;</span>About Us<span class="tag">&lt;/a&gt;</span>

<span class="comment">&lt;!-- Relative link --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"page.html"</span><span class="tag">&gt;</span>Page<span class="tag">&lt;/a&gt;</span>

<span class="comment">&lt;!-- Link to email --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"mailto:info@example.com"</span><span class="tag">&gt;</span>Email Us<span class="tag">&lt;/a&gt;</span>

<span class="comment">&lt;!-- Link to phone --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"tel:+1234567890"</span><span class="tag">&gt;</span>Call Us<span class="tag">&lt;/a&gt;</span>
                    </div>

                    <h3>Anchor Links (Jump to Section)</h3>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Link to section on same page --&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"#section-id"</span><span class="tag">&gt;</span>Jump to Section<span class="tag">&lt;/a&gt;</span>

<span class="comment">&lt;!-- The target element needs an id --&gt;</span>
<span class="tag">&lt;section</span> <span class="attr">id</span>=<span class="string">"section-id"</span><span class="tag">&gt;</span>...<span class="tag">&lt;/section&gt;</span>
                    </div>

                    <h3>Navigation Menu</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;nav&gt;</span>
    <span class="tag">&lt;ul&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a</span> <span class="attr">href</span>=<span class="string">"/"</span><span class="tag">&gt;</span>Home<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a</span> <span class="attr">href</span>=<span class="string">"/about"</span><span class="tag">&gt;</span>About<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a</span> <span class="attr">href</span>=<span class="string">"/contact"</span><span class="tag">&gt;</span>Contact<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
    <span class="tag">&lt;/ul&gt;</span>
<span class="tag">&lt;/nav&gt;</span>
                    </div>

                    <h3>Download Links</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"file.pdf"</span> <span class="attr">download</span><span class="tag">&gt;</span>Download PDF<span class="tag">&lt;/a&gt;</span>
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"file.pdf"</span> <span class="attr">download</span>=<span class="string">"new-name.pdf"</span><span class="tag">&gt;</span>Download with custom name<span class="tag">&lt;/a&gt;</span>
                    </div>

                    <h3>Best Practices</h3>
                    <ul>
                        <li>Use descriptive link text, not "click here"</li>
                        <li>Use absolute URLs for external links</li>
                        <li>Add target="_blank" with rel="noopener" for external links</li>
                        <li>Use the nav element for navigation menus</li>
                    </ul>
                `,
                quiz: [
                    { question: "The _____ element creates hyperlinks.", answer: "a", hint: "Anchor tag" },
                    { question: "The _____ attribute specifies the URL.", answer: "href", hint: "Hypertext reference" },
                    { question: "Use _____ to open link in new tab.", answer: "target", hint: "Attribute name" },
                    { question: "Use _____ for email links.", answer: "mailto", hint: "Protocol" },
                    { question: "Use _____ for anchor links.", answer: "id", hint: "Target identifier" },
                    { question: "Use _____ element for navigation.", answer: "nav", hint: "Semantic wrapper" },
                    { question: "Add _____ for download links.", answer: "download", hint: "Attribute" },
                    { question: "Use _____ for external links security.", answer: "noopener", hint: "rel value" }
                ]
            },
            {
                id: 5,
                title: "Images and Media",
                difficulty: "beginner",
                content: `
                    <h3>The Image Element</h3>
                    <p>Images are essential for visual web content. Use the &lt;img&gt; element with the required src and alt attributes.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"photo.jpg"</span> <span class="attr">alt</span>=<span class="string">"Description of image"</span><span class="tag">&gt;</span>
                    </div>

                    <h3>Essential Image Attributes</h3>
                    <ul>
                        <li><strong>src:</strong> Path to the image file</li>
                        <li><strong>alt:</strong> Alternative text for accessibility and SEO</li>
                        <li><strong>width:</strong> Display width in pixels</li>
                        <li><strong>height:</strong> Display height in pixels</li>
                    </ul>

                    <h3>Image with Dimensions</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;img</span> 
    <span class="attr">src</span>=<span class="string">"photo.jpg"</span> 
    <span class="attr">alt</span>=<span class="string">"A sunset over mountains"</span>
    <span class="attr">width</span>=<span class="string">"800"</span>
    <span class="attr">height</span>=<span class="string">"600"</span>
<span class="tag">&gt;</span>
                    </div>

                    <h3>Image Formats</h3>
                    <ul>
                        <li><strong>JPEG:</strong> Photos, complex images (lossy compression)</li>
                        <li><strong>PNG:</strong> Graphics, transparency, lossless</li>
                        <li><strong>GIF:</strong> Simple animations</li>
                        <li><strong>SVG:</strong> Scalable vector graphics (code-based)</li>
                        <li><strong>WebP:</strong> Modern format, good compression</li>
                    </ul>

                    <h3>Figure and Figcaption</h3>
                    <p>Use &lt;figure&gt; for self-contained content like images with captions.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;figure&gt;</span>
    <span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"chart.png"</span> <span class="attr">alt</span>=<span class="string">"Sales chart"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;figcaption&gt;</span>Figure 1: Annual sales growth 2020-2025<span class="tag">&lt;/figcaption&gt;</span>
<span class="tag">&lt;/figure&gt;</span>
                    </div>

                    <h3>Responsive Images</h3>
                    <p>Use srcset to provide multiple image sizes for different devices.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;img</span> 
    <span class="attr">src</span>=<span class="string">"photo-large.jpg"</span>
    <span class="attr">srcset</span>=<span class="string">"photo-small.jpg 500w, photo-medium.jpg 1000w, photo-large.jpg 2000w"</span>
    <span class="attr">sizes</span>=<span class="string">"(max-width: 600px) 100vw, 50vw"</span>
    <span class="attr">alt</span>=<span class="string">"Responsive photo"</span>
<span class="tag">&gt;</span>
                    </div>

                    <h3>Audio</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;audio</span> <span class="attr">controls</span><span class="tag">&gt;</span>
    <span class="tag">&lt;source</span> <span class="attr">src</span>=<span class="string">"audio.mp3"</span> <span class="attr">type</span>=<span class="string">"audio/mpeg"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;source</span> <span class="attr">src</span>=<span class="string">"audio.ogg"</span> <span class="attr">type</span>=<span class="string">"audio/ogg"</span><span class="tag">&gt;</span>
    Your browser doesn't support audio.
<span class="tag">&lt;/audio&gt;</span>
                    </div>

                    <h3>Video</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;video</span> <span class="attr">controls</span> <span class="attr">width</span>=<span class="string">"640"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;source</span> <span class="attr">src</span>=<span class="string">"video.mp4"</span> <span class="attr">type</span>=<span class="string">"video/mp4"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;source</span> <span class="attr">src</span>=<span class="string">"video.webm"</span> <span class="attr">type</span>=<span class="string">"video/webm"</span><span class="tag">&gt;</span>
    Your browser doesn't support video.
<span class="tag">&lt;/video&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "The _____ attribute provides alt text.", answer: "alt", hint: "Alternative" },
                    { question: "Use _____ for transparent images.", answer: "PNG", hint: "Format" },
                    { question: "Use _____ for vector graphics.", answer: "SVG", hint: "Scalable" },
                    { question: "Wrap image with caption in _____.", answer: "figure", hint: "Semantic" },
                    { question: "Provide multiple sizes with _____.", answer: "srcset", hint: "Source set" },
                    { question: "Use _____ attribute for video controls.", answer: "controls", hint: "Play/pause" },
                    { question: "The _____ element embeds audio.", answer: "audio", hint: "Sound" },
                    { question: "Modern image format is _____.", answer: "WebP", hint: "W-e-b-P" }
                ]
            },
            {
                id: 6,
                title: "Lists",
                difficulty: "beginner",
                content: `
                    <h3>Unordered Lists</h3>
                    <p>Use &lt;ul&gt; for lists where order doesn't matter. Each item uses &lt;li&gt;.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;ul&gt;</span>
    <span class="tag">&lt;li&gt;</span>First item<span class="tag">&lt;/li&gt;</span>
    <span class="tag">&lt;li&gt;</span>Second item<span class="tag">&lt;/li&gt;</span>
    <span class="tag">&lt;li&gt;</span>Third item<span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ul&gt;</span>
                    </div>

                    <h3>Ordered Lists</h3>
                    <p>Use &lt;ol&gt; for lists where order matters—steps, rankings, etc.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;ol&gt;</span>
    <span class="tag">&lt;li&gt;</span>First step<span class="tag">&lt;/li&gt;</span>
    <span class="tag">&lt;li&gt;</span>Second step<span class="tag">&lt;/li&gt;</span>
    <span class="tag">&lt;li&gt;</span>Third step<span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ol&gt;</span>
                    </div>

                    <h3>Ordered List Attributes</h3>
                    <ul>
                        <li><strong>start:</strong> Starting number</li>
                        <li><strong>reversed:</strong> Reverse the order</li>
                        <li><strong>type:</strong> Number type (1, a, A, i, I)</li>
                    </ul>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Start at 5 --&gt;</span>
<span class="tag">&lt;ol</span> <span class="attr">start</span>=<span class="string">"5"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;li&gt;</span>Item 5<span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ol&gt;</span>

<span class="comment">&lt;!-- Lowercase letters --&gt;</span>
<span class="tag">&lt;ol</span> <span class="attr">type</span>=<span class="string">"a"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;li&gt;</span>a. Item<span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ol&gt;</span>

<span class="comment">&lt;!-- Roman numerals --&gt;</span>
<span class="tag">&lt;ol</span> <span class="attr">type</span>=<span class="string">"i"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;li&gt;</span>i. Item<span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ol&gt;</span>
                    </div>

                    <h3>Description Lists</h3>
                    <p>Use &lt;dl&gt; for term/definition pairs. Each term uses &lt;dt&gt;, each definition uses &lt;dd&gt;.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;dl&gt;</span>
    <span class="tag">&lt;dt&gt;</span>HTML<span class="tag">&lt;/dt&gt;</span>
    <span class="tag">&lt;dd&gt;</span>HyperText Markup Language<span class="tag">&lt;/dd&gt;</span>
    
    <span class="tag">&lt;dt&gt;</span>CSS<span class="tag">&lt;/dt&gt;</span>
    <span class="tag">&lt;dd&gt;</span>Cascading Style Sheets<span class="tag">&lt;/dd&gt;</span>
    
    <span class="tag">&lt;dt&gt;</span>JavaScript<span class="tag">&lt;/dt&gt;</span>
    <span class="tag">&lt;dd&gt;</span>Programming language for web<span class="tag">&lt;/dd&gt;</span>
<span class="tag">&lt;/dl&gt;</span>
                    </div>

                    <h3>Nested Lists</h3>
                    <p>Lists can be nested inside each other to create hierarchies.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;ul&gt;</span>
    <span class="tag">&lt;li&gt;</span>Web Development
        <span class="tag">&lt;ul&gt;</span>
            <span class="tag">&lt;li&gt;</span>HTML<span class="tag">&lt;/li&gt;</span>
            <span class="tag">&lt;li&gt;</span>CSS<span class="tag">&lt;/li&gt;</span>
            <span class="tag">&lt;li&gt;</span>JavaScript<span class="tag">&lt;/li&gt;</span>
        <span class="tag">&lt;/ul&gt;</span>
    <span class="tag">&lt;/li&gt;</span>
    <span class="tag">&lt;li&gt;</span>Backend
        <span class="tag">&lt;ul&gt;</span>
            <span class="tag">&lt;li&gt;</span>Node.js<span class="tag">&lt;/li&gt;</span>
            <span class="tag">&lt;li&gt;</span>Python<span class="tag">&lt;/li&gt;</span>
        <span class="tag">&lt;/ul&gt;</span>
    <span class="tag">&lt;/li&gt;</span>
<span class="tag">&lt;/ul&gt;</span>
                    </div>

                    <h3>Styling List Markers</h3>
                    <p>With CSS, you can customize list markers or remove them entirely.</p>
                    
                    <div class="html-block">
<span class="comment">/* Remove markers */</span>
<span class="tag">ul</span> { <span class="attr">list-style</span>: none; }

<span class="comment">/* Custom marker */</span>
<span class="tag">ul</span> { <span class="attr">list-style</span>: square; }
<span class="tag">ol</span> { <span class="attr">list-style</span>: upper-roman; }
                    </div>
                `,
                quiz: [
                    { question: "Use _____ for unordered lists.", answer: "ul", hint: "Unordered" },
                    { question: "Use _____ for ordered lists.", answer: "ol", hint: "Ordered" },
                    { question: "Each list item uses _____.", answer: "li", hint: "List item" },
                    { question: "Use _____ for description lists.", answer: "dl", hint: "Description" },
                    { question: "The definition term uses _____.", answer: "dt", hint: "Term" },
                    { question: "The definition description uses _____.", answer: "dd", hint: "Definition" },
                    { question: "Start ordered list at 5 with _____=5.", answer: "start", hint: "Attribute" },
                    { question: "Use Roman numerals with _____.", answer: "type", hint: "Attribute" }
                ]
            },
            {
                id: 7,
                title: "Tables",
                difficulty: "intermediate",
                content: `
                    <h3>Basic Table Structure</h3>
                    <p>Tables display data in rows and columns using &lt;table&gt;, &lt;tr&gt;, &lt;th&gt;, and &lt;td&gt; elements.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;table&gt;</span>
    <span class="tag">&lt;tr&gt;</span>
        <span class="tag">&lt;th&gt;</span>Header 1<span class="tag">&lt;/th&gt;</span>
        <span class="tag">&lt;th&gt;</span>Header 2<span class="tag">&lt;/th&gt;</span>
    <span class="tag">&lt;/tr&gt;</span>
    <span class="tag">&lt;tr&gt;</span>
        <span class="tag">&lt;td&gt;</span>Data 1<span class="tag">&lt;/td&gt;</span>
        <span class="tag">&lt;td&gt;</span>Data 2<span class="tag">&lt;/td&gt;</span>
    <span class="tag">&lt;/tr&gt;</span>
<span class="tag">&lt;/table&gt;</span>
                    </div>

                    <h3>Table Elements</h3>
                    <ul>
                        <li><strong>&lt;table&gt;</strong> - Container for all table content</li>
                        <li><strong>&lt;tr&gt;</strong> - Table row</li>
                        <li><strong>&lt;th&gt;</strong> - Header cell (bold, centered)</li>
                        <li><strong>&lt;td&gt;</strong> - Data cell</li>
                    </ul>

                    <h3>Table Head, Body, and Footer</h3>
                    <p>Use semantic sections for better structure and styling.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;table&gt;</span>
    <span class="tag">&lt;thead&gt;</span>
        <span class="tag">&lt;tr&gt;</span>
            <span class="tag">&lt;th&gt;</span>Name<span class="tag">&lt;/th&gt;</span>
            <span class="tag">&lt;th&gt;</span>Age<span class="tag">&lt;/th&gt;</span>
        <span class="tag">&lt;/tr&gt;</span>
    <span class="tag">&lt;/thead&gt;</span>
    <span class="tag">&lt;tbody&gt;</span>
        <span class="tag">&lt;tr&gt;</span>
            <span class="tag">&lt;td&gt;</span>Alice<span class="tag">&lt;/td&gt;</span>
            <span class="tag">&lt;td&gt;</span>25<span class="tag">&lt;/td&gt;</span>
        <span class="tag">&lt;/tr&gt;</span>
        <span class="tag">&lt;tr&gt;</span>
            <span class="tag">&lt;td&gt;</span>Bob<span class="tag">&lt;/td&gt;</span>
            <span class="tag">&lt;td&gt;</span>30<span class="tag">&lt;/td&gt;</span>
        <span class="tag">&lt;/tr&gt;</span>
    <span class="tag">&lt;/tbody&gt;</span>
    <span class="tag">&lt;tfoot&gt;</span>
        <span class="tag">&lt;tr&gt;</span>
            <span class="tag">&lt;td&gt;</span>Total<span class="tag">&lt;/td&gt;</span>
            <span class="tag">&lt;td&gt;</span>2<span class="tag">&lt;/td&gt;</span>
        <span class="tag">&lt;/tr&gt;</span>
    <span class="tag">&lt;/tfoot&gt;</span>
<span class="tag">&lt;/table&gt;</span>
                    </div>

                    <h3>Spanning Rows and Columns</h3>
                    <p>Use colspan and rowspan to make cells span multiple rows/columns.</p>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Span 2 columns --&gt;</span>
<span class="tag">&lt;th</span> <span class="attr">colspan</span>=<span class="string">"2"</span><span class="tag">&gt;</span>Full Width Header<span class="tag">&lt;/th&gt;</span>

<span class="comment">&lt;!-- Span 2 rows --&gt;</span>
<span class="tag">&lt;td</span> <span class="attr">rowspan</span>=<span class="string">"2"</span><span class="tag">&gt;</span>Spans 2 rows<span class="tag">&lt;/td&gt;</span>
                    </div>

                    <h3>Table Caption</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;table&gt;</span>
    <span class="tag">&lt;caption&gt;</span>Employee Directory<span class="tag">&lt;/caption&gt;</span>
    <span class="tag">&lt;tr&gt;</span>
        <span class="tag">&lt;th&gt;</span>Name<span class="tag">&lt;/th&gt;</span>
    <span class="tag">&lt;/tr&gt;</span>
<span class="tag">&lt;/table&gt;</span>
                    </div>

                    <h3>Accessibility for Tables</h3>
                    <ul>
                        <li>Always use &lt;th&gt; for header cells</li>
                        <li>Add scope attribute to headers</li>
                        <li>Use captions for descriptions</li>
                        <li>Avoid nested tables when possible</li>
                    </ul>
                    
                    <div class="html-block">
<span class="tag">&lt;th</span> <span class="attr">scope</span>=<span class="string">"col"</span><span class="tag">&gt;</span>Name<span class="tag">&lt;/th&gt;</span>
<span class="tag">&lt;th</span> <span class="attr">scope</span>=<span class="string">"row"</span><span class="tag">&gt;</span>Header<span class="tag">&lt;/th&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "The table container is _____.", answer: "table", hint: "Element" },
                    { question: "Table row is _____.", answer: "tr", hint: "Table row" },
                    { question: "Header cell is _____.", answer: "th", hint: "Table header" },
                    { question: "Data cell is _____.", answer: "td", hint: "Table data" },
                    { question: "Use _____ for column span.", answer: "colspan", hint: "Attribute" },
                    { question: "Use _____ for row span.", answer: "rowspan", hint: "Attribute" },
                    { question: "Table caption uses _____.", answer: "caption", hint: "Element" },
                    { question: "Use _____ for header scope.", answer: "scope", hint: "Attribute" }
                ]
            },
            {
                id: 8,
                title: "Forms and Input",
                difficulty: "intermediate",
                content: `
                    <h3>Basic Form Structure</h3>
                    <p>Forms collect user input with various input types.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;form</span> <span class="attr">action</span>=<span class="string">"/submit"</span> <span class="attr">method</span>=<span class="string">"POST"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;label&gt;</span>Name: <span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"text"</span> <span class="attr">name</span>=<span class="string">"name"</span><span class="tag">&gt;&lt;/label&gt;</span>
    <span class="tag">&lt;button</span> <span class="attr">type</span>=<span class="string">"submit"</span><span class="tag">&gt;</span>Submit<span class="tag">&lt;/button&gt;</span>
<span class="tag">&lt;/form&gt;</span>
                    </div>

                    <h3>Form Attributes</h3>
                    <ul>
                        <li><strong>action:</strong> URL to send form data</li>
                        <li><strong>method:</strong> HTTP method (GET or POST)</li>
                        <li><strong>enctype:</strong> Data encoding type</li>
                        <li><strong>novalidate:</strong> Disable browser validation</li>
                    </ul>

                    <h3>Input Types</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"text"</span><span class="tag">&gt;</span>        <span class="comment">&lt;!-- Text input --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"email"</span><span class="tag">&gt;</span>       <span class="comment">&lt;!-- Email input --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"password"</span><span class="tag">&gt;</span>   <span class="comment">&lt;!-- Hidden text --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"number"</span><span class="tag">&gt;</span>      <span class="comment">&lt;!-- Numbers only --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"tel"</span><span class="tag">&gt;</span>        <span class="comment">&lt;!-- Phone number --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"url"</span><span class="tag">&gt;</span>        <span class="comment">&lt;!-- URL input --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"search"</span><span class="tag">&gt;</span>      <span class="comment">&lt;!-- Search input --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"date"</span><span class="tag">&gt;</span>        <span class="comment">&lt;!-- Date picker --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"checkbox"</span><span class="tag">&gt;</span>   <span class="comment">&lt;!-- Checkbox --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"radio"</span><span class="tag">&gt;</span>      <span class="comment">&lt;!-- Radio button --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"file"</span><span class="tag">&gt;</span>        <span class="comment">&lt;!-- File upload --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"hidden"</span><span class="tag">&gt;</span>     <span class="comment">&lt;!-- Hidden field --&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"submit"</span><span class="tag">&gt;</span>     <span class="comment">&lt;!-- Submit button --&gt;</span>
                    </div>

                    <h3>Labels and Accessibility</h3>
                    <p>Always label your inputs for accessibility.</p>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Method 1: Label wraps input --&gt;</span>
<span class="tag">&lt;label&gt;</span>
    Email: <span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"email"</span> <span class="attr">name</span>=<span class="string">"email"</span><span class="tag">&gt;</span>
<span class="tag">&lt;/label&gt;</span>

<span class="comment">&lt;!-- Method 2: Label with for attribute --&gt;</span>
<span class="tag">&lt;label</span> <span class="attr">for</span>=<span class="string">"username"</span><span class="tag">&gt;</span>Username:<span class="tag">&lt;/label&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">id</span>=<span class="string">"username"</span> <span class="attr">type</span>=<span class="string">"text"</span> <span class="attr">name</span>=<span class="string">"username"</span><span class="tag">&gt;</span>
                    </div>

                    <h3>Textarea and Select</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;textarea</span> <span class="attr">name</span>=<span class="string">"message"</span> <span class="attr">rows</span>=<span class="string">"4"</span> <span class="attr">cols</span>=<span class="string">"30"</span><span class="tag">&gt;&lt;/textarea&gt;</span>

<span class="tag">&lt;select</span> <span class="attr">name</span>=<span class="string">"country"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;option</span> <span class="attr">value</span>=<span class="string">"us"</span><span class="tag">&gt;</span>United States<span class="tag">&lt;/option&gt;</span>
    <span class="tag">&lt;option</span> <span class="attr">value</span>=<span class="string">"uk"</span><span class="tag">&gt;</span>United Kingdom<span class="tag">&lt;/option&gt;</span>
    <span class="tag">&lt;option</span> <span class="attr">value</span>=<span class="string">"ca"</span><span class="tag">&gt;</span>Canada<span class="tag">&lt;/option&gt;</span>
<span class="tag">&lt;/select&gt;</span>
                    </div>

                    <h3>Form Validation Attributes</h3>
                    <ul>
                        <li><strong>required:</strong> Field must be filled</li>
                        <li><strong>min/max:</strong> Number or date limits</li>
                        <li><strong>minlength/maxlength:</strong> Text length</li>
                        <li><strong>pattern:</strong> Regex validation</li>
                    </ul>
                    
                    <div class="html-block">
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"email"</span> <span class="attr">required</span><span class="tag">&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"number"</span> <span class="attr">min</span>=<span class="string">"0"</span> <span class="attr">max</span>=<span class="string">"100"</span><span class="tag">&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">type</span>=<span class="string">"text"</span> <span class="attr">pattern</span>=<span class="string">"[A-Za-z]{3,}"</span><span class="tag">&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "The form element is _____.", answer: "form", hint: "Element" },
                    { question: "Use _____ to send form data.", answer: "POST", hint: "Method" },
                    { question: "Use _____ for email validation.", answer: "email", hint: "Type" },
                    { question: "Use _____ element for labels.", answer: "label", hint: "Element" },
                    { question: "Multi-line input uses _____.", answer: "textarea", hint: "Element" },
                    { question: "Dropdown uses _____ element.", answer: "select", hint: "Element" },
                    { question: "Use _____ to make field mandatory.", answer: "required", hint: "Attribute" },
                    { question: "Use _____ to link label to input.", answer: "for", hint: "Attribute" }
                ]
            },
            {
                id: 9,
                title: "Semantic HTML",
                difficulty: "intermediate",
                content: `
                    <h3>What is Semantic HTML?</h3>
                    <p>Semantic HTML uses elements that clearly describe their meaning. This improves accessibility, SEO, and code readability.</p>
                    
                    <div class="highlight-box">
                        <strong>BENEFITS:</strong> Semantic elements help search engines understand content structure, enable screen readers to navigate properly, and make code easier to maintain.
                    </div>

                    <h3>Structural Elements</h3>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Page header --&gt;</span>
<span class="tag">&lt;header&gt;</span>Site logo and nav<span class="tag">&lt;/header&gt;</span>

<span class="comment">&lt;!-- Navigation --&gt;</span>
<span class="tag">&lt;nav&gt;</span>Menu links<span class="tag">&lt;/nav&gt;</span>

<span class="comment">&lt;!-- Main content --&gt;</span>
<span class="tag">&lt;main&gt;</span>
    <span class="tag">&lt;article&gt;</span>Blog post<span class="tag">&lt;/article&gt;</span>
    <span class="tag">&lt;section&gt;</span>Section<span class="tag">&lt;/section&gt;</span>
<span class="tag">&lt;/main&gt;</span>

<span class="comment">&lt;!-- Sidebar --&gt;</span>
<span class="tag">&lt;aside&gt;</span>Related content<span class="tag">&lt;/aside&gt;</span>

<span class="comment">&lt;!-- Page footer --&gt;</span>
<span class="tag">&lt;footer&gt;</span>Copyright info<span class="tag">&lt;/footer&gt;</span>
                    </div>

                    <h3>Header and Nav</h3>
                    <p>Use &lt;header&gt; for introductory content, &lt;nav&gt; for navigation links.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;header&gt;</span>
    <span class="tag">&lt;h1&gt;</span>Website Title<span class="tag">&lt;/h1&gt;</span>
    <span class="tag">&lt;nav&gt;</span>
        <span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"/"</span><span class="tag">&gt;</span>Home<span class="tag">&lt;/a&gt;</span>
        <span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="string">"/about"</span><span class="tag">&gt;</span>About<span class="tag">&lt;/a&gt;</span>
    <span class="tag">&lt;/nav&gt;</span>
<span class="tag">&lt;/header&gt;</span>
                    </div>

                    <h3>Article and Section</h3>
                    <ul>
                        <li><strong>&lt;article&gt;</strong> - Self-contained content (blog post, news item)</li>
                        <li><strong>&lt;section&gt;</strong> - Thematic grouping of content</li>
                    </ul>
                    
                    <div class="html-block">
<span class="tag">&lt;article&gt;</span>
    <span class="tag">&lt;h2&gt;</span>Blog Post Title<span class="tag">&lt;/h2&gt;</span>
    <span class="tag">&lt;p&gt;</span>Post content...<span class="tag">&lt;/p&gt;</span>
    <span class="tag">&lt;section&gt;</span>
        <span class="tag">&lt;h3&gt;</span>Comments<span class="tag">&lt;/h3&gt;</span>
    <span class="tag">&lt;/section&gt;</span>
<span class="tag">&lt;/article&gt;</span>
                    </div>

                    <h3>Aside</h3>
                    <p>Use &lt;aside&gt; for content tangentially related to the page content.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;main&gt;</span>
    <span class="tag">&lt;article&gt;</span>
        <span class="tag">&lt;p&gt;</span>Main article content...<span class="tag">&lt;/p&gt;</span>
    <span class="tag">&lt;/article&gt;</span>
    <span class="tag">&lt;aside&gt;</span>
        <span class="tag">&lt;h3&gt;</span>Related Articles<span class="tag">&lt;/h3&gt;</span>
    <span class="tag">&lt;/aside&gt;</span>
<span class="tag">&lt;/main&gt;</span>
                    </div>

                    <h3>Figure and Details</h3>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Self-contained content --&gt;</span>
<span class="tag">&lt;figure&gt;</span>
    <span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"chart.png"</span><span class="tag">&gt;</span>
    <span class="tag">&lt;figcaption&gt;</span>Chart description<span class="tag">&lt;/figcaption&gt;</span>
<span class="tag">&lt;/figure&gt;</span>

<span class="comment">&lt;!-- Expandable content --&gt;</span>
<span class="tag">&lt;details&gt;</span>
    <span class="tag">&lt;summary&gt;</span>Click to expand<span class="tag">&lt;/summary&gt;</span>
    <span class="tag">&lt;p&gt;</span>Hidden content<span class="tag">&lt;/p&gt;</span>
<span class="tag">&lt;/details&gt;</span>
                    </div>

                    <h3>Mark and Time</h3>
                    
                    <div class="html-block">
<span class="tag">&lt;p&gt;</span>Today is <span class="tag">&lt;time</span> <span class="attr">datetime</span>=<span class="string">"2026-01-15"</span><span class="tag">&gt;</span>January 15, 2026<span class="tag">&lt;/time&gt;</span>.<span class="tag">&lt;/p&gt;</span>
<span class="tag">&lt;p&gt;</span><span class="tag">&lt;mark&gt;</span>Highlighted<span class="tag">&lt;/mark&gt;</span> text.<span class="tag">&lt;/p&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "Use _____ for page header.", answer: "header", hint: "Element" },
                    { question: "Use _____ for navigation.", answer: "nav", hint: "Element" },
                    { question: "Use _____ for main content.", answer: "main", hint: "Element" },
                    { question: "Use _____ for self-contained content.", answer: "article", hint: "Element" },
                    { question: "Use _____ for thematic sections.", answer: "section", hint: "Element" },
                    { question: "Use _____ for sidebar content.", answer: "aside", hint: "Element" },
                    { question: "Use _____ for page footer.", answer: "footer", hint: "Element" },
                    { question: "Use _____ for expandable content.", answer: "details", hint: "Element" }
                ]
