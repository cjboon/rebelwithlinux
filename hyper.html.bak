            {
                id: 11,
                title: "Accessibility",
                difficulty: "advanced",
                content: `
                    <h3>Why Accessibility Matters</h3>
                    <p>Web accessibility ensures people with disabilities can use your website. It's not just ethical—it also improves SEO and user experience for everyone.</p>
                    
                    <div class="highlight-box">
                        <strong>STATS:</strong> Over 1 billion people worldwide have some form of disability. Accessible websites reach more users and often rank better in search engines.
                    </div>

                    <h3>Alt Text for Images</h3>
                    <p>Always provide descriptive alt text for images.</p>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Descriptive alt text --&gt;</span>
<span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"chart.png"</span> <span class="attr">alt</span>=<span class="string">"Sales increased by 25% in Q4"</span><span class="tag">&gt;</span>

<span class="comment">&lt;!-- Decorative image (empty alt) --&gt;</span>
<span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"decoration.png"</span> <span class="attr">alt</span>=<span class="string">""</span><span class="tag">&gt;</span>

<span class="comment">&lt;!-- Complex image (long description) --&gt;</span>
<span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"chart.png"</span> <span class="attr">alt</span>=<span class="string">"Sales chart"</span> <span class="attr">aria-describedby</span>=<span class="string">"chart-desc"</span><span class="tag">&gt;</span>
<span class="tag">&lt;p</span> <span class="attr">id</span>=<span class="string">"chart-desc"</span><span class="tag">&gt;</span>Detailed description...<span class="tag">&lt;/p&gt;</span>
                    </div>

                    <h3>Form Labels</h3>
                    <p>Every form input needs a label.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;label</span> <span class="attr">for</span>=<span class="string">"email"</span><span class="tag">&gt;</span>Email address:<span class="tag">&lt;/label&gt;</span>
<span class="tag">&lt;input</span> <span class="attr">id</span>=<span class="string">"email"</span> <span class="attr">type</span>=<span class="string">"email"</span> <span class="attr">name</span>=<span class="string">"email"</span><span class="tag">&gt;</span>
                    </div>

                    <h3>Heading Hierarchy</h3>
                    <p>Use headings in logical order. Don't skip levels.</p>
                    
                    <div class="html-block">
<span class="tag">&lt;h1&gt;</span>Page Title<span class="tag">&lt;/h1&gt;</span>
    <span class="tag">&lt;h2&gt;</span>Section<span class="tag">&lt;/h2&gt;</span>
        <span class="tag">&lt;h3&gt;</span>Subsection<span class="tag">&lt;/h3&gt;</span>
        <span class="tag">&lt;h3&gt;</span>Another Subsection<span class="tag">&lt;/h3&gt;</span>
    <span class="tag">&lt;h2&gt;</span>Next Section<span class="tag">&lt;/h2&gt;</span>
                    </div>

                    <h3>Focus States</h3>
                    <p>Ensure interactive elements have visible focus indicators.</p>
                    
                    <div class="html-block">
<span class="comment">/* Never remove focus styles without replacing */</span>
<span class="tag">a:focus</span>, 
<span class="tag">button:focus</span>, 
<span class="tag">input:focus</span> {
    <span class="attr">outline</span>: 3px solid orange;
    <span class="attr">outline-offset</span>: 2px;
}
                    </div>

                    <h3>ARIA Attributes</h3>
                    <p>ARIA provides additional accessibility information.</p>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Hide from screen readers --&gt;</span>
<span class="tag">&lt;div</span> <span class="attr">aria-hidden</span>=<span class="string">"true"</span><span class="tag">&gt;</span>Icon<span class="tag">&lt;/div&gt;</span>

<span class="comment">&lt;!-- Describe button purpose --&gt;</span>
<span class="tag">&lt;button</span> <span class="attr">aria-label</span>=<span class="string">"Close dialog"</span><span class="tag">&gt;</span>×<span class="tag">&lt;/button&gt;</span>

<span class="comment">&lt;!-- Indicate loading state --&gt;</span>
<span class="tag">&lt;div</span> <span class="attr">aria-busy</span>=<span class="string">"true"</span><span class="tag">&gt;</span>Loading...<span class="tag">&lt;/div&gt;</span>

<span class="comment">&lt;!-- Expand/collapse --&gt;</span>
<span class="tag">&lt;button</span> <span class="attr">aria-expanded</span>=<span class="string">"false"</span><span class="tag">&gt;</span>Menu<span class="tag">&lt;/button&gt;</span>
                    </div>

                    <h3>Keyboard Navigation</h3>
                    <ul>
                        <li>All interactive elements must be focusable with Tab</li>
                        <li>Use semantic HTML (&lt;button&gt;, &lt;a&gt;) for interactive elements</li>
                        <li>Ensure keyboard users can trigger all actions</li>
                        <li>Don't trap keyboard focus unexpectedly</li>
                    </ul>

                    <h3>Color Contrast</h3>
                    <p>Ensure sufficient contrast between text and background.</p>
                    <ul>
                        <li>Normal text: Minimum 4.5:1 contrast ratio</li>
                        <li>Large text (18px+): Minimum 3:1 contrast ratio</li>
                        <li>UI components: Minimum 3:1 contrast ratio</li>
                    </ul>
                `,
                quiz: [
                    { question: "Use _____ for image descriptions.", answer: "alt", hint: "Attribute" },
                    { question: "Every form input needs a _____.", answer: "label", hint: "Element" },
                    { question: "Don't skip heading _____.", answer: "levels", hint: "Order" },
                    { question: "Use _____ for screen reader text.", answer: "aria", hint: "Attributes" },
                    { question: "Hide from screen readers with _____ .", answer: "aria-hidden", hint: "Attribute" },
                    { question: "Normal text needs _____ contrast.", answer: "4.5:1", hint: "Ratio" },
                    { question: "All interactive elements must be _____.", answer: "focusable", hint: "Tab key" },
                    { question: "Large text minimum contrast is _____ .", answer: "3:1", hint: "Ratio" }
                ]
            },
            {
                id: 12,
                title: "Best Practices",
                difficulty: "advanced",
                content: `
                    <h3>Valid HTML</h3>
                    <p>Always validate your HTML to ensure it meets web standards.</p>
                    
                    <div class="terminal-block">
<span class="prompt">$</span> <span class="command">Use validator.w3.org to validate your HTML</span>
                    </div>

                    <h3>Document Structure</h3>
                    <ul>
                        <li>Always include DOCTYPE</li>
                        <li>Set lang attribute on html element</li>
                        <li>Include charset and viewport meta tags</li>
                        <li>Use semantic elements (header, nav, main, footer)</li>
                        <li>Only one h1 per page</li>
                    </ul>

                    <h3>Accessibility Checklist</h3>
                    <ul>
                        <li>Alt text for all images</li>
                        <li>Labels for all form inputs</li>
                        <li>Logical heading hierarchy</li>
                        <li>Keyboard-navigable interface</li>
                        <li>Sufficient color contrast</li>
                        <li>ARIA where needed</li>
                    </ul>

                    <h3>Performance Tips</h3>
                    <ul>
                        <li>Optimize images (use appropriate formats)</li>
                        <li>Use lazy loading for images below the fold</li>
                        <li>Minify HTML in production</li>
                        <li>Use CSS for presentation, not tables</li>
                        <li>Defer JavaScript loading</li>
                    </ul>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Lazy load images --&gt;</span>
<span class="tag">&lt;img</span> <span class="attr">src</span>=<span class="string">"image.jpg"</span> <span class="attr">loading</span>=<span class="string">"lazy"</span><span class="tag">&gt;</span>

<span class="comment">&lt;!-- Preload critical resources --&gt;</span>
<span class="tag">&lt;link</span> <span class="attr">rel</span>=<span class="string">"preload"</span> <span class="attr">href</span>=<span class="string">"font.woff2"</span> <span class="attr">as</span>=<span class="string">"font"</span><span class="tag">&gt;</span>
                    </div>

                    <h3>SEO Essentials</h3>
                    <ul>
                        <li>Unique, descriptive title for each page</li>
                        <li>Meta description for search results</li>
                        <li>Semantic HTML helps search engines understand content</li>
                        <li>Use heading hierarchy properly</li>
                        <li>Use meaningful link text</li>
                        <li>Open Graph and Twitter Cards for social sharing</li>
                    </ul>
                    
                    <div class="html-block">
<span class="tag">&lt;title&gt;</span>Page Title - Brand Name<span class="tag">&lt;/title&gt;</span>
<span class="tag">&lt;meta</span> <span class="attr">name</span>=<span class="string">"description"</span> <span class="attr">content</span>=<span class="string">"Description for search engines"</span><span class="tag">&gt;</span>
<span class="tag">&lt;meta</span> <span class="attr">property</span>=<span class="string">"og:title"</span> <span class="attr">content</span>=<span class="string">"Title for social media"</span><span class="tag">&gt;</span>
                    </div>

                    <h3>Code Organization</h3>
                    <ul>
                        <li>Use consistent indentation</li>
                        <li>Comment complex sections</li>
                        <li>Separate concerns (HTML, CSS, JS)</li>
                        <li>Use meaningful class names</li>
                        <li>Keep code DRY (Don't Repeat Yourself)</li>
                    </ul>

                    <h3>Browser Compatibility</h3>
                    <ul>
                        <li>Test in multiple browsers</li>
                        <li>Use progressive enhancement</li>
                        <li>Check caniuse.com for feature support</li>
                        <li>Provide fallbacks for older browsers</li>
                    </ul>

                    <h3>Security Considerations</h3>
                    <ul>
                        <li>Validate all user input</li>
                        <li>Use HTTPS for forms</li>
                        <li>Don't include sensitive data in HTML</li>
                        <li>Escape HTML entities when displaying user content</li>
                        <li>Use Content Security Policy headers</li>
                    </ul>
                    
                    <div class="html-block">
<span class="comment">&lt;!-- Escape user content --&gt;</span>
<span class="tag">&lt;p&gt;</span><span class="tag">&lt;</span>script<span class="tag">&gt;</span>alert('xss')<span class="tag">&lt;/</span>script<span class="tag">&gt;</span><span class="tag">&lt;/p&gt;</span>
<span class="comment">&lt;!-- Renders as text, not executed --&gt;</span>
                    </div>
                `,
                quiz: [
                    { question: "Use _____ to validate HTML.", answer: "validator.w3.org", hint: "Website" },
                    { question: "Use _____ for image lazy loading.", answer: "loading", hint: "Attribute" },
                    { question: "Use _____ for SEO description.", answer: "description", hint: "Meta name" },
                    { question: "Keep code _____ (Don't Repeat Yourself).", answer: "DRY", hint: "Acronym" },
                    { question: "Use _____ for feature support.", answer: "caniuse", hint: "Website" },
                    { question: "Escape _____ entities for security.", answer: "HTML", hint: "Content" },
                    { question: "Use _____ for social sharing.", answer: "Open Graph", hint: "Meta tags" },
                    { question: "Only _____ h1 per page.", answer: "one", hint: "Number" }
                ]
            }
        ];

        function renderLessons() {
            const grid = document.getElementById('lessonsGrid');
            grid.innerHTML = lessons.map(lesson => `
                <div class="lesson-card" onclick="openModal(${lesson.id})">
                    <div class="lesson-number">LESSON ${lesson.id}</div>
                    <h3 class="lesson-title">${lesson.title}</h3>
                    <p class="lesson-desc">Learn HTML from basics to advanced features including semantic markup, forms, and accessibility.</p>
                    <span class="badge badge-${lesson.difficulty}">${lesson.difficulty}</span>
                </div>
            `).join('');
        }

        function openModal(lessonId) {
            const lesson = lessons.find(l => l.id === lessonId);
            if (!lesson) return;

            document.getElementById('modalTitle').textContent = `Lesson ${lesson.id}: ${lesson.title}`;
            
            let content = `
                <div class="lesson-content">
                    ${lesson.content}
                </div>
                <div class="quiz-section">
                    <h3>// Knowledge Check</h3>
                    ${lesson.quiz.map((q, i) => `
                        <div class="quiz-question" data-answer="${q.answer.toLowerCase()}">
                            <p class="question-text">${i + 1}. ${q.question.replace('_____', '<span class="blank"></span>')}</p>
                            <input type="text" class="quiz-input" placeholder="Type your answer..." data-hint="${q.hint}">
                            <p class="quiz-hint">Hint: ${q.hint}</p>
                            <button class="quiz-submit" onclick="checkAnswer(this)">Check Answer</button>
                            <p class="quiz-feedback"></p>
                        </div>
                    `).join('')}
                    <div class="quiz-score">
                        Score: <span class="score-value">0</span>/${lesson.quiz.length}
                    </div>
                </div>
            `;
            
            document.getElementById('modalContent').innerHTML = content;
            document.getElementById('modalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function checkAnswer(btn) {
            const question = btn.closest('.quiz-question');
            const input = question.querySelector('.quiz-input');
            const feedback = question.querySelector('.quiz-feedback');
            const hint = question.querySelector('.quiz-hint');
            const answer = input.value.trim().toLowerCase();
            const correct = question.dataset.answer;

            if (answer === correct) {
                input.classList.add('correct');
                input.classList.remove('incorrect');
                feedback.textContent = '✓ Correct!';
                feedback.classList.add('correct');
                feedback.classList.remove('incorrect');
            } else {
                input.classList.add('incorrect');
                input.classList.remove('correct');
                feedback.textContent = '✗ Try again.';
                feedback.classList.add('incorrect');
                feedback.classList.remove('correct');
                hint.classList.add('visible');
            }

            checkAllAnswers();
        }

        function checkAllAnswers() {
            const questions = document.querySelectorAll('.quiz-question');
            const score = document.querySelector('.score-value');
            const scoreDisplay = document.querySelector('.quiz-score');
            
            let correct = 0;
            questions.forEach(q => {
                const input = q.querySelector('.quiz-input');
                if (input.classList.contains('correct')) correct++;
            });
            
            score.textContent = correct;
            if (correct > 0) scoreDisplay.classList.add('visible');
            
            if (correct === questions.length) {
                const modalContent = document.getElementById('modalContent');
                const lessonMatch = document.getElementById('modalTitle').textContent.match(/Lesson (\d+)/);
                if (lessonMatch) {
                    saveProgress('hyper', parseInt(lessonMatch[1]), true);
                }
            }
        }

        async function saveProgress(course, lessonId, completed) {
            try {
                await fetch('api/progress.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        course: course,
                        lesson_id: parseInt(lessonId),
                        completed: completed
                    }),
                    credentials: 'include'
                });
            } catch (e) {
                console.log('Could not save progress');
            }
        }

        document.getElementById('closeModal').addEventListener('click', () => {
            document.getElementById('modalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        });

        document.getElementById('modalOverlay').addEventListener('click', (e) => {
            if (e.target === document.getElementById('modalOverlay')) {
                document.getElementById('modalOverlay').classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.getElementById('modalOverlay').classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById('progressBar').style.width = scrolled + '%';
        });

        document.addEventListener('DOMContentLoaded', function() {
            renderLessons();
        });

        function toggleTheme() {
            const html = document.documentElement;
            if (html.getAttribute('data-theme') === 'dark') {
                html.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            } else {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
