            </div>
            <div class="resource-card">
                <h3>♿ Accessibility</h3>
                <p>WCAG guidelines</p>
                <a href="https://www.w3.org/WAI/WCAG21/quickref/" target="_blank">wcag quickref</a>
            </div>
        </div>
